# ─── LLM (OpenRouter) ────────────────────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Vector DB (Qdrant) ──────────────────────────────────────────────────────
# Локально: http://localhost:6333 без API key
# Cloud: https://xyz.eu-central.aws.cloud.qdrant.io з API key
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_CHUNKS_COLLECTION=chunks
QDRANT_CACHE_COLLECTION=cache

# ─── Redis (rate limit + counters) ───────────────────────────────────────────
# Локально: redis://localhost:6379/0
# Upstash: rediss://default:<password>@<host>:6379
REDIS_URL=redis://localhost:6379/0

# ─── Cost tracking ───────────────────────────────────────────────────────────
# SQLite файл (на Fly volume у production). Можна замінити на postgres://...
DATABASE_URL=sqlite+aiosqlite:///./data/cost.db

# ─── Observability (Langfuse) ────────────────────────────────────────────────
# https://cloud.langfuse.com → Settings → API keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── App tuning ──────────────────────────────────────────────────────────────
LLM_CONCURRENCY_LIMIT=20
LLM_REQUEST_TIMEOUT_S=15
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600
MAX_INPUT_CHARS=4000
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
