# Скопіюй у .env та підстав реальні значення.
# .env у git не потрапляє (див. кореневий .gitignore).

OPENAI_API_KEY=sk-proj-...

# Ollama — необов'язково, якщо запускаєш локально на дефолтному порту.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Модель OpenAI для порівняння.
OPENAI_MODEL=gpt-4o-mini